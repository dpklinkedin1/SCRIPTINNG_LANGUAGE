19 (a) Substitute word in string (Simple Version)



print "Enter a sentence:\n";
$str = <STDIN>;
chomp($str);

print "Enter word to replace:\n";
$old = <STDIN>;
chomp($old);

print "Enter new word:\n";
$new = <STDIN>;
chomp($new);

$str =~ s/$old/$new/;

print "Updated sentence: $str\n";


