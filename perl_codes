17 (b) Multiplication tables (1–10) using subroutine



sub table {
    my ($n) = @_;
    for ($i = 1; $i <= 10; $i++) {
        print "$n x $i = ", $n*$i, "\n";
    }
    print "\n";
}

for ($num = 1; $num <= 10; $num++) {
    table($num);
}

