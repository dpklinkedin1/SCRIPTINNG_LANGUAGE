19 (b) Validate IP and Email
🔹 Code
print "Enter IP: ";
$ip = <STDIN>; chomp($ip);

if ($ip =~ /^(\d{1,3}\.){3}\d{1,3}$/) {
    print "Valid IP\n";
} else {
    print "Invalid IP\n";
}

print "Enter Email: ";
$email = <STDIN>; chomp($email);

if ($email =~ /^[\w\.\-]+\@[\w\-]+\.[a-zA-Z]{2,}$/) {
    print "Valid Email\n";
} else {
    print "Invalid Email\n";
}




